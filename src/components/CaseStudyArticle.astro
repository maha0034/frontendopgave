---
//@ts-nocheck
import DynamicImage from "@components/helpers/DynamicImage.astro";
import caseStudy from "@data/caseStudy.json";
const { caseName, category, date, image, buttonLabel } = caseStudy.caseDetails;
---

<article class="case-study">
  <header class="case-study__header">
    <div class="case-study__hero-image">
      <DynamicImage imagePath={image} altText={caseName} />
    </div>

    <div class="case-details">
      <dl class="case-details__list">
        <div class="case-details__item">
          <dt class="case-details__label">Case Name</dt>
          <dd class="case-details__value">{caseName}</dd>
        </div>

        <div class="case-details__item">
          <dt class="case-details__label">Category</dt>
          <dd class="case-details__value category">{category}</dd>
        </div>

        <div class="case-details__item">
          <dt class="case-details__label">Date</dt>
          <dd class="case-details__value date">{date}</dd>
        </div>
      </dl>

      <a href="#0" class="case-details__button">{buttonLabel}</a>
    </div>
  </header>

  {
    caseStudy.sections.map((section, index) => (
      <section class="case-study__section">
        {index === 0 ? (
          <h2 class="case-study__title case-study__title--main">
            {section.title}
          </h2>
        ) : (
          <h3 class="case-study__title">{section.title}</h3>
        )}

        {Array.isArray(section.content) ? (
          <>
            {section.content.map((item) => (
              <p class="case-study__text">{item}</p>
            ))}
          </>
        ) : (
          <p class="case-study__text">{section.content}</p>
        )}

        {section.highlights && (
          <ul class="case-study__list">
            {section.highlights.map((highlight) => (
              <li class="case-study__list-item">{highlight}</li>
            ))}
          </ul>
        )}

        {section.image && (
          <div class="case-study__section-image">
            <DynamicImage
              imagePath={section.image}
              altText={section.title}
              width={600}
              height={400}
            />
          </div>
        )}
      </section>
    ))
  }
</article>
